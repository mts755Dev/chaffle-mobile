{
  "expo": {
    "name": "Chaffle",
    "slug": "chaffle-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#4697AF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.chaffle.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Chaffle needs your location to verify raffle eligibility in your state.",
        "NSCameraUsageDescription": "Chaffle needs camera access to scan QR codes.",
        "NSBluetoothAlwaysUsageDescription": "Chaffle uses Bluetooth to connect to the Stripe Reader M2 for in-person payments.",
        "NSBluetoothPeripheralUsageDescription": "Chaffle uses Bluetooth to communicate with the Stripe Reader M2."
      }
    },
    "android": {
      "package": "org.chaffle.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4697AF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Chaffle needs your location to verify raffle eligibility."
        }
      ],
      [
        "@stripe/stripe-terminal-react-native",
        {
          "bluetoothBackgroundMode": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "28e43424-b7f7-44bc-89f1-0f931e4180bd"
      }
    }
  }
}
