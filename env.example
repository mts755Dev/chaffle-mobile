# Chaffle Mobile App Environment Variables
# Copy this file to .env and fill in your values

# API Base URL (your Next.js backend URL)
EXPO_PUBLIC_API_BASE_URL=https://chaffle.org

# Supabase credentials
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe publishable key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Admin email
EXPO_PUBLIC_ADMIN_EMAIL=admin@chaffle.org
