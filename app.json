{
  "expo": {
    "name": "Chaffle",
    "slug": "chaffle",
    "scheme": "chaffle",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chaffleorg.chaffle",
      "buildNumber": "9",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Chaffle needs your location to verify raffle eligibility in your state.",
        "NSCameraUsageDescription": "Chaffle needs camera access to scan QR codes.",
        "NSBluetoothAlwaysUsageDescription": "Chaffle uses Bluetooth to connect to the Stripe Reader M2 for in-person payments.",
        "NSBluetoothPeripheralUsageDescription": "Chaffle uses Bluetooth to communicate with the Stripe Reader M2.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.chaffleorg.chaffle",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4697AF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#4697AF",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Chaffle needs your location to verify raffle eligibility."
        }
      ],
      [
        "@stripe/stripe-terminal-react-native",
        {
          "bluetoothBackgroundMode": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "54f1e2e9-6637-4136-9e2e-62c4a0b09777"
      }
    }
  }
}
